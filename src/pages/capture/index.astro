---
import type { ImageMetadata } from "astro";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Screenshot from "@components/Screenshot.astro";
import { Icon } from "astro-icon/components";
import captureImg from "@assets/capture/step-01-capture.png";
import reviewImg from "@assets/capture/step-03-review.png";
import historicalImg from "@assets/capture/historical-learning.png";
import lineItemImg from "@assets/capture/line-item-extraction.png";

const seo = {
  description:
    "AI-powered receipt and bill capture for UK accounting practices. Integrates with Xero and FreeAgent.",
};

const howItWorksSteps: {
  name: string;
  intent: string;
  image: ImageMetadata | null;
  imageAlt: string;
}[] = [
  {
    name: "Capture",
    intent:
      "Receipts and invoices arrive by upload or email, to an address branded to your practice.",
    image: captureImg,
    imageAlt: "A receipt being submitted to Otto Capture by email",
  },
  {
    name: "Extract",
    intent:
      "Otto reads each document and pulls out the supplier, dates, totals, and line items.",
    image: null,
    imageAlt: "",
  },
  {
    name: "Review",
    intent:
      "Otto suggests the nominal code and tax rate from that client's history, and you check and adjust anything before it goes further.",
    image: reviewImg,
    imageAlt:
      "Reviewing Otto's extracted fields and suggested coding before publishing",
  },
  {
    name: "Publish",
    intent: "Once you're happy, publish straight to your accounting platform.",
    image: null,
    imageAlt: "",
  },
];

type EmailAnatomy = {
  segments: {
    value: string;
    label: string;
    accent: "client" | "practice" | "hosted";
    sep: string;
  }[];
  ownDomain: string;
};

// Colour-codes each address segment: the two meaningful parts (the client and
// the practice) get the brand accents; the hosted domain stays neutral.
const emailAccent: Record<
  EmailAnatomy["segments"][number]["accent"],
  { bar: string; label: string }
> = {
  client: { bar: "bg-primary", label: "text-primary-strong" },
  practice: { bar: "bg-terracotta", label: "text-terracotta-strong" },
  hosted: { bar: "bg-default-soft", label: "text-default-soft" },
};

const differentiators: {
  title: string;
  intent: string;
  icon: string;
  image: ImageMetadata | null;
  imageAlt: string;
  emailExample?: EmailAnatomy;
}[] = [
  {
    title: "Historical learning",
    intent:
      "Otto looks at how you've coded that supplier for that specific client before, and suggests the same nominal code and tax rate for you to confirm. The history stays per client, so one client's coding is never mixed with another's, or with how that supplier is coded elsewhere on the system.",
    icon: "hugeicons:ai-brain-01",
    image: historicalImg,
    imageAlt:
      "Otto suggesting a nominal code from the client's previous coding",
  },
  {
    title: "Line items extracted by default",
    intent:
      "Otto extracts line items as standard, not as a paid extra, so the detail is there when you need it.",
    icon: "hugeicons:check-list",
    image: lineItemImg,
    imageAlt: "Line items extracted from a receipt",
  },
  {
    title: "Practice-branded email submission addresses",
    intent:
      "Each client gets its own submission address on a subdomain dedicated to your practice. Because that subdomain is yours, you can use a clear, consistent alias for each client, rather than competing for names on a shared address where the obvious ones are often already taken.",
    icon: "hugeicons:mail-account-01",
    image: null,
    imageAlt: "",
    emailExample: {
      segments: [
        {
          value: "flower-power",
          label: "the client",
          accent: "client",
          sep: "@",
        },
        {
          value: "top-accountant-limited",
          label: "your practice",
          accent: "practice",
          sep: ".",
        },
        {
          value: "ottocapture.email",
          label: "hosted by Otto",
          accent: "hosted",
          sep: "",
        },
      ],
      ownDomain: "flower-power@receipts.topaccountant.com",
    },
  },
  {
    title: "Transparency and zero data retention",
    intent:
      "Every model we use runs under a zero-data-retention policy, so your documents are not stored by the provider and are never used to train a model, and we're open about how the rest works.",
    icon: "hugeicons:shield-01",
    image: null,
    imageAlt: "",
  },
];

const pricingTiers: {
  name: string;
  price: string;
  included: string;
  extraDocument: string;
}[] = [
  { name: "Small", price: "£9", included: "Up to 50", extraDocument: "18p" },
  { name: "Medium", price: "£15", included: "Up to 125", extraDocument: "12p" },
  { name: "Large", price: "£29", included: "Up to 350", extraDocument: "8p" },
];

const pricingPromises: { label: string; intent: string; icon: string }[] = [
  {
    label: "No documents, no charge.",
    intent:
      "If a client has nothing published in a month, you pay nothing for that client. You are only billed for the clients Otto is actively publishing for.",
    icon: "hugeicons:invoice-01",
  },
  {
    label: "Always the cheapest tier.",
    intent:
      "Each client sits on whichever tier costs least for what it published that month, worked out for you automatically. There is no plan to pick up front, and no need to move clients between plans to chase the best price.",
    icon: "hugeicons:discount-tag-01",
  },
  {
    label: "No price cliffs.",
    intent:
      "Reaching a tier's allowance doesn't tip you straight into the next tier and a much bigger bill. You simply pay the per-document rate for each extra document published, until the next tier works out cheaper, at which point Otto moves that client up for you. Clients busier than the Large tier carry on at the Large per-document rate, so even your highest-volume clients stay predictable.",
    icon: "hugeicons:chart-up",
  },
];

// Section-heading icon chips (large circle, sits above the heading).
const sectionChipLight =
  "inline-flex size-16 shrink-0 items-center justify-center rounded-full bg-primary text-white shadow-sm md:size-20";
const sectionChipDark =
  "inline-flex size-16 shrink-0 items-center justify-center rounded-full bg-white/10 text-white ring-1 ring-white/20 md:size-20";
const sectionChipIcon = "size-7 md:size-8";
// Per-item icon chip (small, sits inline with the item heading).
const itemChip =
  "inline-flex size-12 shrink-0 items-center justify-center rounded-xl bg-primary-soft text-primary-strong";
---

<Layout title="Otto Capture" seo={seo}>
  <!-- Hero -->
  <div class="bg-primary-soft pt-10 md:pt-24">
    <Container>
      <div class="mx-auto max-w-screen-xl pb-16 text-center">
        <div class="mb-6 flex justify-center">
          <span
            class="inline-flex items-center gap-2.5 rounded-full bg-white px-4 py-1.5 text-sm font-medium text-primary-strong shadow-sm">
            Otto Capture
            <span class="size-1 rounded-full bg-primary-medium"></span>
            Now available
          </span>
        </div>
        <h1
          class="mx-auto max-w-4xl text-4xl font-bold text-primary-strong md:text-6xl">
          Receipt capture that learns how your practice codes
        </h1>
        <p class="mx-auto max-w-3xl py-6 text-xl leading-normal text-default">
          Otto extracts each document, suggests the coding from how you've
          handled that client before, and leaves you to review and publish to
          your accounting platform.
        </p>
        <div class="flex justify-center">
          <a
            href="https://capture.withotto.app/register/"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary/30 transition hover:-translate-y-0.5 hover:bg-primary-strong hover:shadow-xl focus-visible:ring-2 focus-visible:ring-primary-strong focus-visible:ring-offset-2 focus-visible:outline-none">
            Start your free trial
            <Icon name="hugeicons:arrow-right-01" class="size-5" />
          </a>
        </div>
        <p class="mt-6 text-sm font-medium text-default-soft">
          Works with Xero and FreeAgent
        </p>
      </div>
    </Container>
  </div>

  <!-- Why we built it (dark feature band) -->
  <div class="bg-primary-strong py-20 text-white">
    <Container>
      <div class="mx-auto max-w-3xl">
        <div class="flex flex-col items-center text-center">
          <span class={sectionChipDark}>
            <Icon name="hugeicons:tools" class={sectionChipIcon} />
          </span>
          <h2 class="mt-5 text-3xl font-bold md:text-5xl">Why we built it</h2>
        </div>
        <div class="mt-8 space-y-4 text-lg text-primary-soft">
          <p>
            We run our own accounting practice, and we'd never found a receipt
            capture tool that ticked all the boxes.
          </p>
          <p>
            So we built one, focused on what actually matters: accurate
            extraction, coding that learns from how you already work, and
            getting documents into your accounting platform with less manual
            effort.
          </p>
        </div>
      </div>
    </Container>
  </div>

  <!-- How it works -->
  <div class="bg-primary-soft py-16">
    <Container>
      <div class="mx-auto max-w-4xl">
        <div class="flex flex-col items-center text-center">
          <span class={sectionChipLight}>
            <Icon name="hugeicons:route-01" class={sectionChipIcon} />
          </span>
          <h2 class="mt-5 text-3xl font-bold text-primary-strong md:text-5xl">
            How it works
          </h2>
        </div>
        <div class="mt-12 space-y-16">
          {
            howItWorksSteps.map((step, index) => (
              <div>
                <div class="flex items-center gap-4">
                  <div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-white font-semibold text-primary-strong">
                    {index + 1}
                  </div>
                  <h3 class="text-2xl font-semibold text-primary-strong">
                    {step.name}
                  </h3>
                </div>
                <p class="mt-3 text-lg text-default">{step.intent}</p>
                {step.image && (
                  <Screenshot src={step.image} alt={step.imageAlt} />
                )}
              </div>
            ))
          }
        </div>
      </div>
    </Container>
  </div>

  <!-- What makes it different -->
  <div class="py-16">
    <Container>
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col items-center text-center">
          <span class={sectionChipLight}>
            <Icon name="hugeicons:sparkles" class={sectionChipIcon} />
          </span>
          <h2 class="mt-5 text-3xl font-bold text-primary-strong md:text-5xl">
            What makes it different
          </h2>
        </div>
        <div class="mt-12 space-y-16">
          {
            differentiators.map((item, index) =>
              item.image ? (
                <div class="grid items-start gap-10 md:grid-cols-2">
                  {/* md:mt-8 lines the heading up with the top of the
                      Screenshot, which carries a 2rem flow margin. */}
                  <div
                    class:list={[
                      "md:mt-8",
                      index % 2 === 1 && "md:order-last",
                    ]}>
                    <div class="flex items-center gap-3">
                      <span class={itemChip}>
                        <Icon name={item.icon} class="size-6" />
                      </span>
                      <h3 class="text-2xl font-semibold text-primary-strong">
                        {item.title}
                      </h3>
                    </div>
                    <p class="mt-4 text-lg text-default">{item.intent}</p>
                  </div>
                  <Screenshot src={item.image} alt={item.imageAlt} />
                </div>
              ) : (
                <div class="mx-auto max-w-3xl">
                  <div class="flex items-center gap-3">
                    <span class={itemChip}>
                      <Icon name={item.icon} class="size-6" />
                    </span>
                    <h3 class="text-2xl font-semibold text-primary-strong">
                      {item.title}
                    </h3>
                  </div>
                  <p class="mt-4 text-lg text-default">{item.intent}</p>
                  {item.emailExample && (
                    <div class="mt-6 rounded-xl border border-muted-strong bg-muted-soft p-5 md:p-6">
                      <div class="flex flex-wrap items-start gap-x-1.5 gap-y-4">
                        {item.emailExample.segments.map((seg) => (
                          <Fragment>
                            <span class="flex flex-col">
                              <span class="font-mono text-sm text-default md:text-base">
                                {seg.value}
                              </span>
                              <span
                                class:list={[
                                  "mt-1.5 h-0.5 rounded-full",
                                  emailAccent[seg.accent].bar,
                                ]}
                              />
                              <span
                                class:list={[
                                  "mt-1.5 text-xs font-medium",
                                  emailAccent[seg.accent].label,
                                ]}>
                                {seg.label}
                              </span>
                            </span>
                            {seg.sep && (
                              <span class="font-mono text-sm text-default-soft md:text-base">
                                {seg.sep}
                              </span>
                            )}
                          </Fragment>
                        ))}
                      </div>
                      <div class="mt-5 border-t border-muted-strong pt-4">
                        <p class="text-sm text-default-soft">
                          Prefer your own domain? Point it at Otto instead:
                        </p>
                        <p class="mt-2 font-mono text-sm text-default md:text-base">
                          {item.emailExample.ownDomain}
                        </p>
                      </div>
                    </div>
                  )}
                </div>
              ),
            )
          }
        </div>
      </div>
    </Container>
  </div>

  <!-- Accuracy and staying in control (dark feature band) -->
  <div class="bg-primary-strong py-20 text-white">
    <Container>
      <div class="mx-auto max-w-3xl">
        <div class="flex flex-col items-center text-center">
          <span class={sectionChipDark}>
            <Icon name="hugeicons:target-01" class={sectionChipIcon} />
          </span>
          <h2 class="mt-5 text-3xl font-bold md:text-5xl">
            Accuracy and staying in control
          </h2>
        </div>
        <div class="mt-8 space-y-4 text-lg text-primary-soft">
          <p>
            Otto reads each document and proposes the detail and coding. You
            stay in control of what reaches your accounting platform, reviewing
            and adjusting as much as you need. Behind the scenes we measure
            accuracy rigorously against real coding decisions, rather than
            asking you to take quality on trust.
          </p>
        </div>
      </div>
    </Container>
  </div>

  <!-- Who it's for -->
  <div class="py-16">
    <Container>
      <div class="mx-auto max-w-3xl">
        <div class="flex flex-col items-center text-center">
          <span class={sectionChipLight}>
            <Icon name="hugeicons:user-multiple" class={sectionChipIcon} />
          </span>
          <h2 class="mt-5 text-3xl font-bold text-primary-strong md:text-5xl">
            Who it's for
          </h2>
        </div>
        <p class="mt-8 text-lg text-default">
          Otto Capture suits any practice that handles receipts and bills in
          Xero or FreeAgent, from a sole practitioner to a firm with a large
          client book. What makes it useful tends to matter more as you grow,
          not less.
        </p>
        <p class="mt-8 space-y-4 text-lg text-default">
          Coding is learned for each client separately, so every client keeps
          its own treatment and your records stay consistent no matter how many
          of your team work on them. Line items are extracted from every
          document, not as a paid extra, so the detail behind mixed tax rates
          and split nominal codes is captured whether a client sends fifty
          documents a month or several hundred. The result is less manual entry
          and cleaner records, which frees up your own time if you work alone,
          and your team's if you don't.
        </p>
      </div>
    </Container>
  </div>

  <!-- Pricing -->
  <div class="bg-primary-soft py-16">
    <Container>
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col items-center text-center">
          <span class={sectionChipLight}>
            <Icon name="hugeicons:coins-01" class={sectionChipIcon} />
          </span>
          <h2 class="mt-5 text-3xl font-bold text-primary-strong md:text-5xl">
            Pricing
          </h2>
        </div>
        <p class="mx-auto mt-8 max-w-3xl text-lg text-default">
          Otto Capture is priced per client, per month, and you only pay for the
          documents Otto publishes. There are three tiers, and each client is
          always placed on the one that costs least.
        </p>

        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {
            pricingTiers.map((tier) => (
              <div class="flex flex-col rounded-xl border border-muted-strong bg-white p-6 shadow-sm">
                <h3 class="text-lg font-semibold text-primary-strong">
                  {tier.name}
                </h3>
                <p class="mt-3 flex items-baseline gap-1.5">
                  <span class="text-4xl font-bold text-primary-strong">
                    {tier.price}
                  </span>
                  <span class="text-sm text-default-soft">
                    per client, per month
                  </span>
                </p>
                <dl class="mt-6 space-y-4 border-t border-muted-strong pt-6 text-sm">
                  <div>
                    <dt class="text-default-soft">
                      Included published documents
                    </dt>
                    <dd class="mt-0.5 text-base font-semibold text-default">
                      {tier.included}
                    </dd>
                  </div>
                  <div>
                    <dt class="text-default-soft">Each extra document</dt>
                    <dd class="mt-0.5 text-base font-semibold text-default">
                      {tier.extraDocument}
                    </dd>
                  </div>
                </dl>
              </div>
            ))
          }
        </div>
        <p class="mt-6 text-center text-sm text-default-soft">
          Prices exclude VAT.
        </p>

        <div class="mt-16 space-y-4">
          {
            pricingPromises.map((promise) => (
              <div class="flex items-start gap-4 rounded-xl border border-muted-strong bg-white p-5 md:p-6">
                <span class="inline-flex size-11 shrink-0 items-center justify-center rounded-xl bg-primary-soft text-primary-strong">
                  <Icon name={promise.icon} class="size-6" />
                </span>
                <p class="text-default">
                  <span class="font-semibold text-primary-strong">
                    {promise.label}
                  </span>{" "}
                  {promise.intent}
                </p>
              </div>
            ))
          }
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4 text-lg text-default">
          <p>
            Only documents published to your accounting platform are charged:
            not duplicates, not documents you've discarded, and not documents
            still waiting to be reviewed.
          </p>
          <p>
            Otto Capture is free to trial for 30 days, extended to 60 for
            practices joining during our Xero App Store launch. After the trial,
            the prices above apply.{" "}
            <a
              href="https://capture.withotto.app/register/"
              class="font-semibold text-primary-strong underline underline-offset-2 hover:text-primary">
              Start your free trial
            </a>{" "}
            to begin.
          </p>
        </div>
      </div>
    </Container>
  </div>

  <!-- What's next -->
  <div class="py-16">
    <Container>
      <div class="mx-auto max-w-3xl">
        <div class="rounded-xl border border-muted-strong bg-white p-6">
          <div class="mb-3 flex items-center gap-3">
            <Icon
              name="hugeicons:route-01"
              class="size-6 shrink-0 text-primary-strong"
            />
            <h2 class="text-2xl font-semibold text-primary-strong">
              What's next
            </h2>
          </div>
          <p class="text-default">
            Requesting missing documents from your clients is next, followed by
            WhatsApp submission. We'll add features here as they ship.
          </p>
        </div>
      </div>
    </Container>
  </div>

  <!-- Get started -->
  <div class="bg-primary-soft py-16" id="get-started">
    <Container>
      <div class="mx-auto max-w-3xl">
        <div class="flex flex-col items-center text-center">
          <span class={sectionChipLight}>
            <Icon name="hugeicons:user-add-01" class={sectionChipIcon} />
          </span>
          <h2 class="mt-5 text-3xl font-bold text-primary-strong md:text-5xl">
            Get started
          </h2>
          <p class="mt-6 text-lg text-default-soft">
            Otto Capture is open to UK accounting and bookkeeping practices.
            Create your account, connect your first client's Xero, and start
            your free trial. It takes a few minutes.
          </p>
          <div class="mt-8 flex justify-center">
            <a
              href="https://capture.withotto.app/register/"
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary/30 transition hover:-translate-y-0.5 hover:bg-primary-strong hover:shadow-xl focus-visible:ring-2 focus-visible:ring-primary-strong focus-visible:ring-offset-2 focus-visible:outline-none">
              Start your free trial
              <Icon name="hugeicons:arrow-right-01" class="size-5" />
            </a>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- Honesty note -->
  <div class="py-16">
    <Container>
      <div class="mx-auto max-w-3xl">
        <div
          class="flex items-start gap-4 rounded-lg border-l-4 border-primary bg-primary-soft p-6">
          <Icon
            name="hugeicons:information-circle"
            class="mt-0.5 size-6 shrink-0 text-primary-strong"
          />
          <p class="text-default">
            Otto Capture is a newer product and we're developing it actively. If
            something isn't right, or there's a feature you'd like to see, tell
            us. Support comes direct from the team that builds it.
          </p>
        </div>
      </div>
    </Container>
  </div>
</Layout>
