---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import FeaturesCol from "@components/features-col.astro";
import StatsGrid from "@components/StatsGrid.astro";
import Pricing from "@components/pricing.astro";
import BookingForm from "@components/BookingForm.astro";

const seo = {
  title: "Otto Bank Rec - With Otto",
  description:
    "Otto's machine learning automatically matches bank transactions with bookkeeping entries in Xero, saving your practice hours of manual reconciliation work.",
};
---

<Layout title="Otto Bank Rec" seo={seo}>
  <div class="bg-primary-soft pt-10 md:pt-24">
    <Container>
      <div class="mx-auto max-w-screen-xl pb-16">
        <h1
          class="mx-auto max-w-4xl text-center text-4xl font-bold text-primary-strong md:text-6xl">
          Bank reconciliation that learns how you work
        </h1>
        <p
          class="mx-auto max-w-3xl py-6 text-center text-xl leading-normal text-default">
          Otto Bank Rec is built for practices and finance teams whose
          reconciliation needs go beyond automated rules. Plenty of teams get
          what they need from JAX, and if that is you, great. Otto is for the
          cases where you need more.
        </p>
        <div class="mb-12 flex justify-center">
          <a
            href="#start-a-trial"
            class="rounded-lg bg-primary px-6 py-3 font-medium text-white shadow transition hover:bg-primary-strong">
            Start a trial
          </a>
        </div>
        <StatsGrid />
      </div>
    </Container>
  </div>

  <div class="py-24">
    <Container>
      <div class="mx-auto max-w-4xl">
        <h2
          class="text-center text-3xl font-bold text-primary-strong md:text-5xl">
          What makes Otto different
        </h2>
        <div class="mt-12 grid gap-8 md:grid-cols-3">
          <div>
            <h3 class="text-xl font-semibold text-primary-strong">
              Intelligent matching
            </h3>
            <p class="mt-2 text-default">
              Otto draws on your own reconciliation history rather than relying
              on fixed assumptions.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-primary-strong">
              Decisions you can see
            </h3>
            <p class="mt-2 text-default">
              Otto shows why he matched each transaction, so you stay in
              control.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-primary-strong">
              Improves as you correct it
            </h3>
            <p class="mt-2 text-default">
              Your corrections feed back in, so the same issue does not keep
              recurring month after month.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <div class="py-24" id="features">
    <Container>
      <div>
        <h2
          class="text-center text-3xl font-bold text-primary-strong md:text-5xl">
          How Otto works in your practice
        </h2>
        <p class="mx-auto mt-6 max-w-4xl text-lg text-default">
          Otto handles the repetitive matching so your team can focus on the
          work that needs judgement. He learns each client's reconciliation
          history, reconciles the matches he is confident about, and leaves the
          rest for you to check. Whether you look after a handful of clients or
          hundreds, Otto works the same way.
        </p>
      </div>
      <div class="mt-20">
        <FeaturesCol />
      </div>
    </Container>
  </div>

  <Pricing />

  <div class="py-24" id="start-a-trial">
    <Container>
      <div class="mx-auto max-w-3xl">
        <h2
          class="text-center text-3xl font-bold text-primary-strong md:text-5xl">
          Start a trial
        </h2>
        <p class="mx-auto mt-6 max-w-3xl text-center text-lg text-default">
          A proper introduction makes the difference. Book an hour of guided
          setup and we'll get Otto working with your practice from the start.
        </p>
        <p class="mx-auto mt-6 max-w-3xl text-default">In the session we'll:</p>
        <ul class="mx-auto mt-2 max-w-3xl list-disc space-y-1 pl-5 text-default">
          <li>understand what you want Otto to help with</li>
          <li>
            explain how Otto learns from each client's reconciliation history
          </li>
          <li>
            show you around the portal, where you monitor and configure Otto
          </li>
          <li>help you invite Otto and assign your first trial clients</li>
          <li>answer any questions on security, compliance, and best practice</li>
        </ul>
        <p class="mx-auto mt-6 max-w-3xl text-default">
          There's no pressure and no obligation to continue.
        </p>
      </div>
      <BookingForm />
    </Container>
  </div>
</Layout>
